# Copy to terraform.tfvars and fill in — this file is gitignored.
# Sensitive values can also be passed as TF_VAR_ environment variables
# (which is what the GitHub Actions deploy job does).

db_password      = "change-me-strong-password"
rails_master_key = "your-rails-master-key-from-api/config/master.key"

# Optionally override defaults:
# db_instance_class     = "db.t3.micro"
# elasticache_node_type = "cache.t3.micro"
# api_cpu               = 512
# api_memory            = 1024
# web_cpu               = 256
# web_memory            = 512
